<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Poignée -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#E5E1EC"
        android:backgroundTint="#5B4FCF"/>

    <!-- Titre -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Laisser un avis"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:fontFamily="@font/poppins_bold"
        android:layout_marginBottom="4dp"/>

    <!-- Sous-titre artisan -->
    <TextView
        android:id="@+id/tv_artisan_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#5B4FCF"
        android:layout_marginBottom="24dp"/>

    <!-- Label note -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Votre note (1 à 10)"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <!-- Slider note 1–10 -->
    <com.google.android.material.slider.Slider
        android:id="@+id/slider_rating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="1"
        android:valueTo="10"
        android:stepSize="1"
        android:value="5"
        app:thumbColor="#5B4FCF"
        app:trackColorActive="#5B4FCF"
        app:trackColorInactive="#E5E1EC"
        app:labelBehavior="floating"
        android:layout_marginBottom="8dp"/>

    <!-- Aperçu étoiles + valeur -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <RatingBar
            android:id="@+id/rating_bar_preview"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:isIndicator="true"
            android:progressTint="#FFB300"
            android:rating="2.5"/>

        <TextView
            android:id="@+id/tv_rating_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="5 / 10"
            android:textSize="13sp"
            android:textColor="#787585"/>

    </LinearLayout>

    <!-- Label commentaire -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Votre commentaire"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <!-- Champ commentaire -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_comment"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Décrivez votre expérience..."
            android:textSize="14sp"
            android:textColor="#1A1A2E"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:padding="14dp"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Bouton Envoyer -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_submit_review"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_button_gradient"
        android:text="Envoyer l'avis"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:stateListAnimator="@null"
        android:layout_marginBottom="8dp"/>

    <!-- Bouton Annuler -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:text="Annuler"
        android:textColor="#787585"
        android:textSize="14sp"
        android:stateListAnimator="@null"/>

</LinearLayout>