<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream">

    <!-- ═══════════════════════════════════ -->
    <!--    HEADER (vert épuré)              -->
    <!-- ═══════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/emerald"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/circle_white"
            android:src="@drawable/ic_person"
            android:padding="10dp"
            android:scaleType="centerCrop"
            app:tint="@color/emerald" />

        <TextView
            android:id="@+id/tv_other_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textColor="@color/text_on_dark"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_bold" />

    </LinearLayout>

    <!-- ═══════════════════════════════════ -->
    <!--    LISTE MESSAGES                   -->
    <!-- ═══════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:paddingVertical="12dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- ═══════════════════════════════════ -->
    <!--    ZONE DE SAISIE                   -->
    <!-- ═══════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface_white"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:layout_marginBottom="16dp"
        android:elevation="8dp"
        android:gravity="center_vertical">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Votre message..."
            android:maxLines="3"
            android:background="@drawable/bg_search_bar_light"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginEnd="10dp" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/circle_terracotta"
            android:src="@drawable/ic_add"
            android:padding="12dp"
            app:tint="@color/surface_white" />

    </LinearLayout>
</LinearLayout>