<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Nom artisan + Badge statut -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tv_artisan_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:fontFamily="@font/poppins_bold"/>

            <TextView
                android:id="@+id/tv_offer_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Prix -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_category_icon_active"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_star_filled"
                android:layout_marginEnd="8dp"
                app:tint="#5B4FCF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prix : "
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#5B4FCF"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Délai -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_info"
                android:layout_marginEnd="8dp"
                app:tint="#787585"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Délai : "
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:id="@+id/tv_delay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#787585"/>

        </LinearLayout>

        <!-- Message -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Message :"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tv_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#787585"
                android:lineSpacingMultiplier="1.4"
                android:background="@drawable/bg_search_bar_light"
                android:padding="12dp"/>

        </LinearLayout>

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E1EC"
            android:layout_marginBottom="14dp"/>

        <!-- Bouton profil artisan -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_view_artisan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_gradient"
            android:text="Voir profil artisan"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:layout_marginBottom="8dp"/>

        <!-- Bouton contacter -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_chat_artisan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_gradient"
            android:text="Contacter l'artisan"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:layout_marginBottom="12dp"/>

        <!-- Boutons Accepter / Refuser -->
        <LinearLayout
            android:id="@+id/layout_accept_reject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_accept"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_green"
                android:text="Accepter"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:layout_marginEnd="8dp"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_reject"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_logout"
                android:text="Refuser"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>