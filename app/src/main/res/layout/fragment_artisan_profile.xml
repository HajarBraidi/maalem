<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mon profil"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvArtisanEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#9E9E9E"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvValidationStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            android:background="#EEEEEE" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Nom complet"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#6C47FF"
            app:hintTextColor="#6C47FF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etArtisanName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1A1A2E"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="Téléphone"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#6C47FF"
            app:hintTextColor="#6C47FF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etArtisanPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:textColor="#1A1A2E"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="Spécialité (ex: plomberie, électricité)"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#6C47FF"
            app:hintTextColor="#6C47FF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etArtisanSpecialty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1A1A2E"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="Ville"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#6C47FF"
            app:hintTextColor="#6C47FF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etArtisanCity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1A1A2E"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="Bio (parlez de vous et de votre expérience)"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#6C47FF"
            app:hintTextColor="#6C47FF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etArtisanBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:gravity="top"
                android:textColor="#1A1A2E"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSaveArtisanProfile"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="Enregistrer"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_button_gradient"
            android:stateListAnimator="@null"
            app:cornerRadius="14dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnArtisanLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="Déconnexion"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_button_logout"
            android:stateListAnimator="@null"
            app:cornerRadius="14dp" />

        <!-- ★ SECTION AVIS -->

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E1EC"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Titre section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mes avis clients"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:fontFamily="@font/poppins_bold"
            android:layout_marginBottom="12dp"/>

        <!-- Note moyenne -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_bar_light"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <RatingBar
                android:id="@+id/rating_bar_my_average"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="0.1"
                android:isIndicator="true"
                android:progressTint="#FFB300"
                android:rating="0"/>

            <TextView
                android:id="@+id/tv_my_average_rating"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textSize="13sp"
                android:textColor="#787585"
                android:text="Aucun avis pour le moment"/>

            <!-- Badge nombre d'avis -->
            <TextView
                android:id="@+id/tv_review_count_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_category_icon_active"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#5B4FCF"
                android:text="0 avis"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Liste des avis (RecyclerView) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_my_reviews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="16dp"/>

        <!-- État vide avis -->
        <TextView
            android:id="@+id/tv_no_reviews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="😊 Aucun avis reçu pour le moment"
            android:textSize="13sp"
            android:textColor="#BDBDBD"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>
    </LinearLayout>
</ScrollView>