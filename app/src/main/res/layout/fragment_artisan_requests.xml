<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream">

    <!-- ═══════════════════════════════════ -->
    <!--    HEADER ZELLIGE (110dp)           -->
    <!-- ═══════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="@drawable/bg_header_zellige">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/zellige_bg"
            android:scaleType="centerCrop"
            android:alpha="0.22"
            android:contentDescription="@null" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/header_gradient_end"
            android:alpha="0.45" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">

            <TextView
                android:id="@+id/tvRequestsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Demandes disponibles"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_dark"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/tvRequestsSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dans votre spécialité"
                android:textSize="14sp"
                android:textColor="#E6FFFFFF"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Conteneur pour progress / vide / liste -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ProgressBar
            android:id="@+id/requestsProgress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/emerald" />

        <TextView
            android:id="@+id/tvEmptyRequests"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Aucune demande disponible pour le moment"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:gravity="center"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRequests"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingHorizontal="8dp"
            android:paddingBottom="16dp" />

    </FrameLayout>

</LinearLayout>